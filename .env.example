# Banco de dados (SQLite por padrão — zero configuração para rodar local)
DATABASE_URL="file:./dev.db"

# Segredo para assinar o token JWT da sessão (troque por algo aleatório)
JWT_SECRET="troque-este-segredo-em-producao-com-uma-string-bem-longa"

# Chave para criptografar as senhas dos portais dos bancos (AES-256-GCM).
# Troque por uma string aleatória longa e mantenha em segredo. Se não definida,
# cai no JWT_SECRET. Em produção use um KMS/secret manager.
CREDENTIALS_KEY="troque-esta-chave-de-credenciais-em-producao"

# Chave da API da Anthropic (Claude) — usada na análise inteligente das propostas.
# Opcional: sem a chave, a plataforma usa um fallback heurístico e continua funcionando.
ANTHROPIC_API_KEY=""

# Modelo da Claude usado na análise (padrão: claude-opus-4-8)
ANTHROPIC_MODEL="claude-opus-4-8"

# --- RPA (robô Playwright nos portais dos bancos) ---
# Lista (separada por vírgula) de bancos cuja consulta deve ser feita via robô
# no portal, em vez do motor simulado. No demo, esses bancos são consultados no
# portal-banco MOCK servido pelo próprio app (/mock-banco).
# Ex.: RPA_BANCOS="Banco Pan"
RPA_BANCOS=""

# URL base do app (o robô usa para acessar o portal mock).
APP_BASE_URL="http://localhost:3000"

# headless=false abre o navegador visível (útil para depurar a automação).
RPA_HEADLESS="true"
